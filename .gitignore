*.py[cod]
*$py.class
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# ==========================================
# Virtual Environments
# ==========================================
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

